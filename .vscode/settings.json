{
    "clangd.arguments": [
        "-background-index",
        "--header-insertion=never"
    ],
    "clangd.fallbackFlags": [
        "-std=c++17",
        "-pedantic",
        "-Wall",
        "-I${workspaceFolder}/src/include",
        "-IC:/Programs/msys64/mingw64/include",
        "-DLLVM_VERSION=18"
    ],
    "clangd.path": "C:/Programs/msys64/mingw64/bin/clangd.exe",
    "editor.autoClosingBrackets": "never",
    "editor.autoClosingDelete": "never",
    "editor.autoClosingOvertype": "never",
    "editor.autoClosingQuotes": "never",
    "[cpp]": {
        "editor.autoClosingBrackets": "never",
        "editor.autoClosingQuotes": "never",
        "editor.autoClosingOvertype": "never",
        "editor.autoClosingDelete": "never"
    },
    // start "%CONTITLE%" "%WD%mintty" -i "/%CONICON%" -t "%CONTITLE%" "/usr/bin/%LOGINSHELL%" -l !SHELL_ARGS!
    "terminal.integrated.profiles.windows": {
        "MSYS2 MINGW64": {
            "path": "C:\\Programs\\msys64\\usr\\bin\\bash.exe",
            "args": [
                "--login", "-i"
            ],
            "env": {
                "MSYSTEM": "MINGW64",
                "CHERE_INVOKING": "1"
            }
        }
    }
}